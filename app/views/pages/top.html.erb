<% content_for :head do %>
  <%= javascript_include_tag("pages/top") %>
<% end %>

<main>
  <% if flash[:notice] %>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-6">
      <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm">
        <%= flash[:notice] %>
      </div>
    </div>
  <% end %>

  <%# Hero section %>
  <% if !logged_in? %>
    <section class="max-w-3xl mx-auto px-4 sm:px-6 pt-16 pb-12 text-center">
      <a href="<%= login_path %>" class="text-3xl font-bold text-gray-900 mb-6">
        会員登録・ログイン
      </a>
    </section>
  <% end %>

  <%# About section %>
  <section class="bg-gray-50 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">
        ABOUT <span class="text-primary">WHATIF?</span>
      </h2>
      <p class="text-base text-gray-600 leading-loose">
        実用的なビジネス英会話より、映画のふとしたフレーズが頭に残る。<br>
        それはきっと情景とともにあなたの脳に記憶されているから。<br>
        <br>
        このアプリは、物語のワンシーンのような状況で英語を学ぶことができます。<br>
        「次はどんな場面が来るんだろう？」<br>
        純粋な好奇心で続けられる学びを目指します。
      </p>
    </div>
  </section>

  <%# Scenes section %>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-3">SCENES</h2>
    <p class="text-center text-gray-500 mb-10">好きなシーンを選んでください。</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @situations.each do |situation| %>
        <%= link_to situation_path(situation),
              class: "group block bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg hover:scale-105 transition-all duration-300" do %>
          <div class="aspect-video overflow-hidden bg-gray-100">
            <%= image_tag situation.thumbnail, class: "w-full h-full object-cover", alt: situation.title %>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-gray-900 text-sm mb-2 leading-snug">
              <%= situation.title %>
            </h3>
            <p class="text-xs text-gray-500 leading-relaxed line-clamp-3">
              <%= situation.overview %>
            </p>
          </div>
          <div class="px-4 pb-4">
            <span class="inline-flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full px-4 py-1.5 group-hover:opacity-80 transition-opacity">
              はじめる
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
</main>
