<main class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
  <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2">STUDY LOG</p>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-10">
    <%= @study_log.loggable.title %>
  </h1>

  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8 max-w-sm mx-auto mb-10 transition-colors duration-200">
    <div class="mb-6">
      <p class="text-xs font-bold text-gray-400 dark:text-gray-500 tracking-widest uppercase mb-2">実施日時</p>
      <p class="text-gray-900 dark:text-white text-base font-semibold">
        <%= l(@study_log.studied_at, format: :long) %>
      </p>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700 pt-6">
      <p class="text-xs font-bold text-gray-400 dark:text-gray-500 tracking-widest uppercase mb-2">正答数</p>
      <p class="text-4xl font-bold text-primary">
        <%= @study_log.correct_count %>
      </p>
    </div>
  </div>

  <%= link_to "学習記録一覧へ戻る", studylogs_path,
        class: "inline-flex items-center justify-center bg-primary text-white font-bold rounded-full px-10 py-3 hover:opacity-80 transition-opacity duration-300" %>
</main>
