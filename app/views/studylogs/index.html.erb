<main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
  <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2 text-center">STUDY LOG</p>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">学習履歴</h1>

  <div class="flex justify-center gap-6 mb-10">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 px-8 py-5 text-center transition-colors duration-200">
      <p class="text-xs font-bold tracking-widest text-gray-400 dark:text-gray-500 uppercase mb-1">連続学習日数</p>
      <p class="text-3xl font-bold text-primary"><%= @login_streak %><span class="text-base font-normal text-gray-500 dark:text-gray-400 ml-1">日</span></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 px-8 py-5 text-center transition-colors duration-200">
      <p class="text-xs font-bold tracking-widest text-gray-400 dark:text-gray-500 uppercase mb-1">累計学習記録</p>
      <p class="text-3xl font-bold text-primary"><%= @total_study_count %><span class="text-base font-normal text-gray-500 dark:text-gray-400 ml-1">回</span></p>
    </div>
  </div>

  <% if @study_logs.empty? %>
    <div class="text-center py-16 text-gray-400 dark:text-gray-600">
      <p class="text-base">学習履歴がありません</p>
    </div>
  <% else %>
    <ul class="space-y-4">
      <% @study_logs.each do |log| %>
        <li class="block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 hover:shadow-md transition-all duration-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs font-bold text-gray-400 dark:text-gray-500 tracking-widest uppercase mb-1">
                <%= log.loggable_type %>
              </p>
              <p class="font-bold text-gray-900 dark:text-white text-base">
                <%= link_to log.loggable.title, situation_path(log.loggable) %>
              </p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                <%= l(log.studied_at) %>
              </p>
            </div>
            <div class="text-right ml-4">
              <p class="text-xs font-bold text-gray-400 dark:text-gray-500 tracking-widest uppercase mb-1">正答率</p>
              <p class="text-3xl font-bold text-primary"><%= log.correct_rate %><span class="text-base font-normal text-gray-500 dark:text-gray-400 ml-1">%</span></p>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>

  <div class="mt-10 text-center">
    <%= link_to "TOPへ戻る", root_path,
          class: "inline-flex items-center justify-center bg-primary text-white font-bold rounded-full px-10 py-3 hover:opacity-80 transition-opacity duration-300" %>
  </div>
</main>
