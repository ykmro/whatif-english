<main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
  <p class="text-xs font-bold tracking-widest text-primary uppercase mb-2 text-center">STUDY LOG</p>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-6 text-center">学習履歴</h1>

  <div class="flex justify-center gap-6 mb-10">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-8 py-5 text-center">
      <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-1">連続ログイン</p>
      <p class="text-3xl font-bold text-primary"><%= @login_streak %><span class="text-base font-normal text-gray-500 ml-1">日</span></p>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-8 py-5 text-center">
      <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-1">最終ログイン</p>
      <p class="text-lg font-bold text-gray-900"><%= @last_login_date&.strftime("%Y年%m月%d日") || "−" %></p>
    </div>
  </div>

  <% if @study_logs.empty? %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-base">学習履歴がありません</p>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @study_logs.each do |log| %>
        <%= link_to studylog_path(log), class: "block bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow duration-200" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-1">
                <%= log.loggable_type %>
              </p>
              <p class="font-bold text-gray-900 text-base">
                <%= log.loggable.title %>
              </p>
              <p class="text-xs text-gray-400 mt-1">
                <%= log.studied_at %>
              </p>
            </div>
            <div class="text-right ml-4">
              <p class="text-xs font-bold text-gray-400 tracking-widest uppercase mb-1">正答数</p>
              <p class="text-3xl font-bold text-primary"><%= log.correct_count %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="mt-10 text-center">
    <%= link_to "TOPへ戻る", root_path,
          class: "inline-flex items-center justify-center bg-primary text-white font-bold rounded-full px-10 py-3 hover:opacity-80 transition-opacity duration-300" %>
  </div>
</main>
