<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50 transition-colors duration-200">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <h1>
      <a href="/" class="flex items-center hover:opacity-60 transition-opacity duration-300">
        <%= image_tag "header/logo.png", class: "h-8 w-auto", alt: "WHATIF?" %>
      </a>
    </h1>
    <nav class="flex items-center gap-4">
      <button data-controller="theme" data-action="click->theme#toggle"
              class="p-2 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
              aria-label="ダークモード切替">
        <svg data-theme-icon="sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <svg data-theme-icon="moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="rgb(255 59 48)" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
      <% if logged_in? %>
        <%= link_to "学習履歴", studylogs_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors" %>
        <%= link_to "ログアウト", logout_path, data: { turbo_method: "delete" }, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors mr-10" %>
      <% else %>
        <%= link_to "ログイン", login_path, class: "text-sm px-5 py-2 rounded-full transition-colors border border-primary text-primary dark:border-white dark:text-white" %>
        <%= link_to "会員登録", new_user_path, class: "text-sm px-5 py-2 text-white rounded-full transition-colors", style: "background-color: rgb(255 59 48);" %>
      <% end %>
    </nav>
  </div>
</header>
