<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <h1>
      <a href="/" class="flex items-center hover:opacity-60 transition-opacity duration-300">
        <%= image_tag "header/logo.png", class: "h-8 w-auto", alt: "WHATIF?" %>
      </a>
    </h1>
    <nav class="flex items-center gap-4">
      <% if logged_in? %>
        <%= link_to "学習履歴", studylogs_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors mr-10" %>
        <%= link_to "ログアウト", logout_path, data: { turbo_method: "delete" }, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors mr-10" %>
      <% else %>
        <%= link_to "ログイン", login_path, class: "text-sm px-5 py-2 rounded-full transition-colors", style: "border: 1px solid rgb(255 59 48); color: rgb(255 59 48);" %>
        <%= link_to "会員登録", new_user_path, class: "text-sm px-5 py-2 text-white rounded-full transition-colors", style: "background-color: rgb(255 59 48);" %>
      <% end %>
    </nav>
  </div>
</header>
